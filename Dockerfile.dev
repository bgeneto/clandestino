# syntax=docker/dockerfile:1

# ---------------------------------------------------------------------------
# Imagem de DESENVOLVIMENTO compartilhada por api e web.
# Instala todas as dependências do monorepo e pré-compila os pacotes
# compartilhados (que são consumidos via ./dist). O código-fonte de
# apps/api e apps/web é montado por volume no compose para hot reload.
# Contexto de build esperado: raiz do monorepo (ver docker-compose.dev.yml).
# ---------------------------------------------------------------------------

FROM node:22-bookworm-slim
ENV PNPM_HOME="/pnpm" \
    PATH="/pnpm:$PATH"
RUN corepack enable
WORKDIR /app

# Instala dependências a partir dos manifests (melhor cache).
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json tsconfig.base.json ./
COPY packages/shared-contracts/package.json packages/shared-contracts/
COPY packages/tournament-engine/package.json packages/tournament-engine/
COPY apps/api/package.json apps/api/
COPY apps/web/package.json apps/web/
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile

# Copia o restante do código (node_modules e dist são ignorados via .dockerignore).
COPY . .

# Pré-compila os pacotes compartilhados — api e web os importam por ./dist.
RUN pnpm --filter @clandestino/shared-contracts build \
 && pnpm --filter @clandestino/tournament-engine build

EXPOSE 3000 5173
