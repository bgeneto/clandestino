# Obrigatória — caminho do arquivo SQLite (formato Drizzle file:)
# Use este caminho relativo ao rodar a API/migrações no HOST (fora do Docker),
# ex.: `pnpm --filter @clandestino/api db:migrate` ou `pnpm dev`.
# Relativo a apps/api → gera apps/api/data/clandestino.db.
# NÃO use `file:/app/data/clandestino.db` aqui: esse caminho é interno ao
# container Docker (definido no docker-compose*.yml). No host ele não existe
# e o migrate falha com "Cannot open database because the directory does not exist".
DATABASE_URL=file:./data/clandestino.db

# Servidor Fastify
API_HOST=0.0.0.0
API_PORT=3000

# URL base do PWA (usada nos magic links)
PUBLIC_APP_URL=http://localhost:5173

# Acesso do organizador
ORGANIZER_ALLOWED_EMAILS=organizador@gmail.com
ORGANIZER_MAGIC_LINK_TTL_MINUTES=15
ORGANIZER_SESSION_TTL_HOURS=168

# Em dev (NODE_ENV != production) o magic link é retornado na resposta JSON.
# Defina como true para forçar esse comportamento; false para desativar.
# Em produção (NODE_ENV=production) o magic link NUNCA é exposto, mesmo com true.
# EXPOSE_MAGIC_LINKS=true

# Anti-abuso das rotas de magic link (organizador)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MINUTES=15

# E-mail (Resend) — obrigatório em produção (NODE_ENV=production)
EMAIL_FROM=admin@sistema.pro.br
EMAIL_FROM_NAME=Clandestino - Tênis de Mesa
RESEND_API_KEY=re_bw...

# Limite de tamanho do corpo aceito na importação CSV (bytes; padrão 1 MiB)
CSV_IMPORT_MAX_BYTES=1048576

# Arquivo SQLite dedicado aos testes de integração (opcional).
# Se ausente, a suíte de integração é ignorada (describe.skipIf).
# TEST_DATABASE_URL=file:./data/clandestino_test.db
