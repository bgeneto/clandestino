{
  "name": "clandestino",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:all": "pnpm test && pnpm --filter @clandestino/web test && TEST_DATABASE_URL=file:./data/clandestino_test.db pnpm --filter @clandestino/api test",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write --ignore-unknown apps packages docker docs \"*\" \".*\"",
    "format:check": "prettier --check --ignore-unknown apps packages docker docs \"*\" \".*\"",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm format:check && pnpm typecheck && pnpm test"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs,json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "glob": "^13.0.6",
      "source-map": "^0.7.4"
    }
  }
}
