#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# Clandestino — wrapper seguro para subir ambientes dev e prod via Docker Compose.
#
#   ./start dev            # stack dev (api + web + caddy)
#   ./start dev --seed       # idem, com seed de exemplo no start
#   ./start prod             # api + web-build (Caddy externo)
#   ./start --help
#
# Migrações: automáticas no start da API (dev command / prod entrypoint).
# Seed: só permitido em dev (--seed → SEED_ON_START=true).
# ---------------------------------------------------------------------------
set -euo pipefail

readonly ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly COMPOSE_DEV="${ROOT_DIR}/docker-compose.dev.yml"
readonly COMPOSE_PROD="${ROOT_DIR}/docker-compose.yml"
readonly DEV_HOST="clandestino.test"

usage() {
  cat <<'EOF'
Uso: ./start <dev|prod> [opções]

Ambientes:
  dev              Sobe api + web + caddy (hot reload, http://clandestino.test)
                   Assets do PWA (ícones, etc.) servidos ao vivo pelo Vite.
  prod             Sobe api + web-build (Caddy externo com file_server)
                   Reconstrói imagens e recria containers a cada execução.

Opções:
  --seed           (só dev) Popula dados de exemplo após migrar
  --help, -h       Mostra esta ajuda

Variáveis:
  CLANDESTINO_WEB_ROOT      Destino dos estáticos (padrão: ./srv/clandestino; use /srv/clandestino em prod)
  PUBLIC_APP_URL            URL pública do PWA (magic links; use https em prod)
  VITE_API_URL              Prefixo da API no build do PWA (padrão: /api)
  VITE_SHOW_PLAYER_SHUFFLE  Flag Vite opcional (lida do .env na raiz)
  ORGANIZER_SESSION_TTL_HOURS  Validade da sessão do organizador em horas (padrão 720)

Exemplos:
  ./start dev
  ./start dev --seed
  ./start prod

Migrações rodam automaticamente no start da API.
Seed nunca é permitido em prod.

Parar:
  ./stop            # detecta a stack ativa e para
  ./stop dev        # para a stack dev
  ./stop prod       # para a stack prod

Packages (shared-contracts / tournament-engine):
  ./start dev recompila os pacotes no container da API e reinicia a API.
  Com a stack já rodando após git pull, prefira: ./stop dev && ./start dev
EOF
}

rebuild_dev_packages() {
  local compose_file="${COMPOSE_DEV}"

  if ! compose_running "${compose_file}"; then
    return 0
  fi

  log "Recompilando shared-contracts e tournament-engine no container da API..."
  if docker compose -f "${compose_file}" exec -T api sh -c \
    'pnpm --filter @clandestino/shared-contracts build && pnpm --filter @clandestino/tournament-engine build'; then
    docker compose -f "${compose_file}" restart api >/dev/null
    log "  Packages atualizados; serviço api reiniciado."
  else
    warn "Falha ao recompilar packages (API pode ainda estar subindo)."
    warn "Tente: ./stop dev && ./start dev"
    warn "Se a API não sobe (502), veja README — seção «Parar / logs / rebuild»."
  fi
}

log() {
  printf '[start] %s\n' "$*"
}

warn() {
  printf '[start] AVISO: %s\n' "$*" >&2
}

die() {
  printf '[start] ERRO: %s\n' "$*" >&2
  exit 1
}

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    die "Docker não encontrado. Instale Docker e tente novamente."
  fi
  if ! docker compose version >/dev/null 2>&1; then
    die "docker compose não disponível. Instale Docker Compose v2."
  fi
}

compose_running() {
  local compose_file="$1"
  local ids
  ids="$(docker compose -f "${compose_file}" ps -q 2>/dev/null || true)"
  [[ -n "${ids}" ]]
}

assert_no_other_stack() {
  local target="$1"
  if [[ "${target}" == "dev" ]]; then
    if compose_running "${COMPOSE_PROD}"; then
      die "A stack prod está rodando. Pare antes: docker compose down"
    fi
  else
    if compose_running "${COMPOSE_DEV}"; then
      die "A stack dev está rodando. Pare antes: docker compose -f docker-compose.dev.yml down"
    fi
  fi
}

start_prod() {
  assert_no_other_stack "prod"

  log "Reconstruindo imagens de produção (api + PWA)..."
  SEED_ON_START=false docker compose -f "${COMPOSE_PROD}" build api web-build

  log "Subindo stack de produção (api + export do PWA para CLANDESTINO_WEB_ROOT)..."
  # --force-recreate: web-build é one-shot (cp dist → volume); sem isso o PWA antigo permanece.
  SEED_ON_START=false docker compose -f "${COMPOSE_PROD}" up -d --force-recreate --remove-orphans

  log "Stack prod em segundo plano."
  log "  API:  clandestino-api:3000 (rede clandestino — conecte o Caddy externo)"
  log "  PWA:  ${CLANDESTINO_WEB_ROOT:-./srv/clandestino} (file_server no Caddy externo)"
  log "  Logs: docker compose logs -f"
  log "  Parar: ./stop prod"
}

warn_hosts_entry() {
  local hosts_file=""
  if [[ -r /etc/hosts ]]; then
    hosts_file="/etc/hosts"
  fi

  if [[ -n "${hosts_file}" ]] && grep -qE "[[:space:]]${DEV_HOST}([[:space:]]|$)" "${hosts_file}" 2>/dev/null; then
    return 0
  fi

  warn "Entrada '${DEV_HOST}' não encontrada em /etc/hosts."
  warn "Adicione:  127.0.0.1   ${DEV_HOST}"
  warn "No WSL2, edite o hosts do Windows (C:\\Windows\\System32\\drivers\\etc\\hosts)."
}

start_dev() {
  local seed="${1:-false}"

  assert_no_other_stack "dev"
  warn_hosts_entry

  log "Subindo stack de desenvolvimento (api + web + caddy)..."
  if [[ "${seed}" == "true" ]]; then
    log "Seed habilitado (SEED_ON_START=true)."
    SEED_ON_START=true docker compose -f "${COMPOSE_DEV}" up -d --build
  else
    SEED_ON_START=false docker compose -f "${COMPOSE_DEV}" up -d --build
  fi

  rebuild_dev_packages

  log "Stack dev em segundo plano."
  log "  PWA:        http://clandestino.test"
  log "  API health: http://clandestino.test/api/health"
  log "  Logs:       docker compose -f docker-compose.dev.yml logs -f"
  log "  Parar:      ./stop dev"
  log "  Packages:   recompilados em todo ./start dev (mudanças em packages/*)"
}

main() {
  require_docker

  local env=""
  local seed="false"

  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help | -h)
        usage
        exit 0
        ;;
      --seed)
        seed="true"
        shift
        ;;
      dev | prod)
        if [[ -n "${env}" ]]; then
          die "Especifique apenas um ambiente: dev ou prod."
        fi
        env="$1"
        shift
        ;;
      *)
        die "Argumento desconhecido: $1 (use --help)"
        ;;
    esac
  done

  if [[ -z "${env}" ]]; then
    usage
    exit 1
  fi

  if [[ "${env}" == "prod" && "${seed}" == "true" ]]; then
    die "Seed não é permitido em prod. Use: ./start dev --seed"
  fi

  case "${env}" in
    dev)
      start_dev "${seed}"
      ;;
    prod)
      start_prod
      ;;
    *)
      die "Ambiente inválido: ${env}"
      ;;
  esac
}

main "$@"
